# TMDB API key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=replace_with_your_tmdb_api_key

# Ingestion controls
TMDB_MAX_PAGES=5
TMDB_DISCOVER_SORT_BY=revenue.desc
TMDB_VOTE_COUNT_GTE=50

# PostgreSQL / dbt connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=movies
POSTGRES_USER=itc6050
POSTGRES_PASSWORD=itc6050

DBT_HOST=localhost
DBT_PORT=5432
DBT_DBNAME=movies
DBT_USER=itc6050
DBT_PASSWORD=itc6050
DBT_SCHEMA=analytics

